# =============================================================================
# 咖啡烘焙系统前端环境变量示例
# 复制为 .env.local 后按需修改。提交时不要包含真实密钥。
# =============================================================================

# 后端 API 基础地址（不含末尾斜杠）
VITE_API_BASE_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# 演示模式开关
#   false = 走真实后端 API（联调 / 生产）
#   不设置或其它值 = 演示模式（前端读取内置 mock 数据，刷新后不保存）
# 联调时务必显式设为 false，避免误以为已对接后端。
# -----------------------------------------------------------------------------
VITE_DEMO_MODE=false

# -----------------------------------------------------------------------------
# 部署基础路径
#   本地 / Nginx 根路径: / 或不设置
#   GitHub Pages:         /Coffee_bean_bake_system/
# -----------------------------------------------------------------------------
VITE_BASE_PATH=/
